{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://everarcade.example/specs/world-evr-core-v1.schema.json",
  "title": "WORLD_EVR_CORE_SPEC_V1 manifest bundle",
  "type": "object",
  "required": ["manifest", "runtime", "modules", "rigs", "fixtures", "proofs", "migrations", "restore", "trust", "signatures"],
  "properties": {
    "manifest": {
      "type": "object",
      "required": ["core_spec", "world_id", "world_name", "version", "package_version", "authors", "license", "description"],
      "properties": {
        "core_spec": { "const": "WORLD_EVR_CORE_SPEC_V1" },
        "world_id": { "type": "string", "minLength": 1 },
        "world_name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "package_version": { "type": "string", "minLength": 1 },
        "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "license": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "runtime": { "type": "object", "required": ["runtime_version", "abi_version", "tick", "memory_limits", "fuel_limits"] },
    "modules": { "type": "object", "required": ["modules"], "properties": { "modules": { "type": "array" } } },
    "rigs": { "type": "object", "required": ["rigs"], "properties": { "rigs": { "type": "array" } } },
    "fixtures": { "type": "object", "required": ["action_logs", "replay_fixtures", "snapshots", "expected_roots"] },
    "proofs": { "type": "object", "required": ["state_root", "receipt_root", "continuity_root", "world_hash", "package_hash"] },
    "migrations": { "type": "object", "required": ["migration_metadata", "migration_history", "migration_proofs"] },
    "restore": { "type": "object", "required": ["checkpoints", "snapshots", "restore_metadata", "restore_proofs"] },
    "trust": { "type": "object", "required": ["attestations", "certification_providers", "review_history", "known_assumptions"] },
    "signatures": { "type": "object", "required": ["developer_signatures", "operator_signatures", "certification_signatures"] }
  },
  "additionalProperties": true
}

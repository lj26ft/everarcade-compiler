{
  "name": "everarcade-compiler-workspace",
  "private": true,
  "version": "0.1.0",
  "description": "EverArcade deterministic compiler/runtime validation workspace.",
  "workspaces": [
    "frontend/creator-dashboard",
    "frontend/player-portal",
    "frontend/operator-console",
    "frontend/shared-ui",
    "frontend/shared-api",
    "frontend/shared-types",
    "frontend/shared-wallet",
    "frontend-gateway"
  ],
  "scripts": {
    "test": "node --test frontend/tests/run_frontend_integration_tests.mjs",
    "frontend:validate": "bash scripts/run_frontend_validation.sh",
    "certify:federation": "node runtime/arena_hotpocket/validation/certify-federation.js",
    "certify:restore": "node runtime/arena_hotpocket/validation/certify-restore.js",
    "certify:migration": "node runtime/arena_hotpocket/validation/certify-migration.js",
    "certify:root-integrity": "node runtime/arena_hotpocket/validation/certify-root-integrity.js",
    "certify:js-kernel-equivalence": "node runtime/arena_hotpocket/validation/certify-js-kernel-equivalence.js",
    "package:formal-proof-target": "node scripts/package-formal-proof-target.js"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "dependencies": {
    "@mermaid-js/layout-elk": "^0.1.9",
    "clsx": "^2.1.1"
  }
}
